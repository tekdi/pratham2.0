# -----------------------------------------------------------------------------
# Survey Nest upstream — used by survey-forms Next.js rewrites only.
# Browser uses same-origin /api/*; server forwards to this host.
# -----------------------------------------------------------------------------
SURVEY_API_UPSTREAM_URL=https://dev-survey.prathamdigital.org
# Or fallback (optional if SURVEY_API_UPSTREAM_URL is set):
# NEXT_PUBLIC_SURVEY_API_BASE_URL=https://dev-survey.prathamdigital.org

# -----------------------------------------------------------------------------
# Middleware API — required by teacher-specific routes (/teacher-survey-list,
# /teacher-survey-fill/**) to fetch the teacher's cohorts (centers) and their
# cohort members (learners). Same host/port used by other MFEs.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MIDDLEWARE_URL=https://dev-interface.prathamdigital.org/interface/v1

# -----------------------------------------------------------------------------
# basePath — must match the basePath in next.config.js ('/plp-surveys').
# Used by axios to prefix all /api/* calls so they route correctly through
# the Next.js rewrite proxy when served behind a sub-path.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_PATH=/plp-surveys
